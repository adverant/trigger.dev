# Nexus Trigger.dev Plugin - Secrets Template
#
# IMPORTANT: Do NOT commit actual secrets to version control.
# Copy this file to secrets.yaml and replace base64 placeholders with real values.
#
# To encode a value to base64:
#   echo -n "your-value" | base64
#
# To apply:
#   kubectl apply -f secrets.yaml
#
apiVersion: v1
kind: Secret
metadata:
  name: nexus-trigger-secrets
  namespace: nexus
  labels:
    app: nexus-trigger
    app.kubernetes.io/name: nexus-trigger
    app.kubernetes.io/component: secrets
type: Opaque
data:
  # Trigger.dev secret key (from your Trigger.dev project settings)
  # echo -n "tr_dev_xxxxxxxxxxxxxxxxxxxx" | base64
  TRIGGER_SECRET_KEY: REPLACE_WITH_BASE64_ENCODED_VALUE

  # Trigger.dev personal access token (from Trigger.dev dashboard > Settings > API Keys)
  # echo -n "tr_pat_xxxxxxxxxxxxxxxxxxxx" | base64
  TRIGGER_PAT: REPLACE_WITH_BASE64_ENCODED_VALUE

  # Nexus API key (from Nexus dashboard > Settings > API Keys)
  # echo -n "nxk_xxxxxxxxxxxxxxxxxxxx" | base64
  NEXUS_API_KEY: REPLACE_WITH_BASE64_ENCODED_VALUE
