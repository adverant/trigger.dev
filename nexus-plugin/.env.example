# ============================================
# Nexus Trigger Plugin - Environment Variables
# ============================================

# --- Plugin Identity ---
NEXUS_PLUGIN_ID=nexus-trigger
NEXUS_PLUGIN_VERSION=1.0.0
NODE_ENV=production
PORT=8080

# --- Trigger.dev Configuration ---
# Mode: 'self-hosted' (deploy within K8s cluster) or 'external' (connect to existing instance)
TRIGGER_MODE=self-hosted
# Trigger.dev webapp URL (self-hosted default)
TRIGGER_API_URL=http://trigger-dev-webapp:3030
# Secret key for environment-scoped API access (tr_dev_* or tr_prod_*)
TRIGGER_SECRET_KEY=
# Personal Access Token for cross-project Management API access (tr_pat_*)
TRIGGER_PAT=
# Project reference (e.g., proj_xxx)
TRIGGER_PROJECT_REF=
# Environment: dev, staging, production
TRIGGER_ENVIRONMENT=dev

# --- Database ---
POSTGRES_HOST=nexus-postgres.nexus.svc.cluster.local
POSTGRES_PORT=5432
POSTGRES_DATABASE=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=
POSTGRES_SSL=false
POSTGRES_MAX_CONNECTIONS=20

# --- Redis ---
REDIS_URL=redis://nexus-redis.nexus.svc.cluster.local:6379

# --- Nexus Auth ---
NEXUS_AUTH_URL=http://nexus-auth.nexus.svc.cluster.local:9100
NEXUS_API_KEY=

# --- Nexus Service URLs ---
GRAPHRAG_URL=http://nexus-graphrag-enhanced:9051
MAGEAGENT_URL=http://nexus-mageagent:8080
FILEPROCESS_URL=http://nexus-fileprocess:9040
LEARNINGAGENT_URL=http://nexus-learningagent:8094
GEOAGENT_URL=http://nexus-mageagent:8080
JUPYTER_URL=http://nexus-jupyter-auth-proxy:8888
CVAT_URL=http://nexus-cvat-auth-proxy:8080
GPU_BRIDGE_URL=http://nexus-gpu-bridge:8090
SANDBOX_URL=http://nexus-sandbox:9080
N8N_URL=http://nexus-n8n:5678

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json

# --- UI ---
UI_BUILD_PATH=./ui/out
