          "Email support (24h response)"
        ]
      },
      {
        "name": "Business",
        "displayName": "Business",
        "price": 4900,
        "period": "month",
        "limits": {
          "invocationsPerMonth": 500000,
          "concurrentRuns": 100,
          "schedules": 200,
          "retentionDays": 90,
          "teamSeats": 10
        },
        "features": [
          "500,000 task invocations/month",
          "100 concurrent runs",
          "200 cron schedules",
          "90-day log retention",
          "10 team seats (additional $10/seat)",
          "Slack integration + alerts",
          "Priority support (4h response)",
          "Custom task definitions",
          "SLA: 99.5% uptime"
        ]
      },
      {
        "name": "Enterprise",
        "displayName": "Enterprise",
        "price": -1,
        "period": "month",
        "contact": "sales@adverant.ai",
        "limits": {
          "invocationsPerMonth": -1,
          "concurrentRuns": -1,
          "schedules": -1,
          "retentionDays": 365,
          "teamSeats": -1
        },
        "features": [
          "Unlimited task invocations",
          "Unlimited concurrent runs",
          "Unlimited cron schedules",
          "365-day log retention",
          "Unlimited team seats",
          "Dedicated support engineer",
          "Custom integrations",
          "SLA: 99.95% uptime",
          "RBAC, audit trails, SSO"
        ]
      }
    ]
  },
  "marketplace": {
    "category": "automation",
    "subcategory": "orchestration",
    "featured": true,
    "tags": [
      "durable-execution",
      "background-jobs",
      "task-scheduling",
      "cron",
      "workflow-automation",
      "ai-orchestration",
      "human-in-the-loop",
      "retry-logic",
      "event-driven"
    ],
    "screenshots": [
      "/trigger/ui/screenshots/dashboard.png",
      "/trigger/ui/screenshots/run-viewer.png",
      "/trigger/ui/screenshots/workflow-designer.png",
      "/trigger/ui/screenshots/schedule-manager.png"
    ]
  },
  "build": {
    "docker": {
      "file": "nexus-plugin/Dockerfile",
      "context": "nexus-plugin",
      "buildArgs": {
        "BUILD_ID": "${BUILD_ID}",
        "BUILD_TIMESTAMP": "${BUILD_TIMESTAMP}",
        "GIT_COMMIT": "${GIT_COMMIT}",
        "GIT_BRANCH": "${GIT_BRANCH}",
        "VERSION": "${VERSION}"
      },
      "labels": {
        "org.opencontainers.image.title": "Nexus Trigger.dev Plugin",
        "org.opencontainers.image.vendor": "Adverant AI",
        "org.opencontainers.image.licenses": "Apache-2.0"
      }
    },
    "registry": {
      "host": "ghcr.io",
      "repository": "adverant/nexus-trigger",
      "tags": ["latest", "${VERSION}", "${GIT_COMMIT}"]
    }
  },
  "deployment": {
    "namespace": "nexus",
    "serviceAccount": "nexus-trigger",
    "strategy": {
      "type": "RollingUpdate",
      "maxSurge": 1,
      "maxUnavailable": 0
    }
  },
  "networking": {
    "istio": {
      "enabled": true,
      "gateway": "nexus-stack-gateway",
      "virtualService": true,
      "destinationRule": true
    },
    "ingress": {
      "enabled": true,
      "className": "istio",
      "hosts": ["api.adverant.ai"],
      "paths": [
        "/trigger/ui",
        "/trigger/api/v1",
        "/trigger/ws",
        "/trigger/health",
        "/trigger/ready",
        "/trigger/live",
        "/trigger/metrics"
      ]
    }
  },
  "testing": {
    "unit": "npm run test",
    "integration": "npm run test:integration",
    "coverage": {
      "minimum": 80,
      "reportFormats": ["text", "lcov"]
    }
  },
  "ci": {
    "pipeline": ".github/workflows/nexus-plugin-ci.yml",
    "stages": ["lint", "typecheck", "test", "build"],
    "triggers": {
      "push": ["main"],
      "pullRequest": ["main"]
    }
  }
}
